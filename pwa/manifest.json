{
  "name": "Kymacache",
  "short_name": "Kymacache",
  "description": "AI-powered knowledge capture",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f0f0f",
  "theme_color": "#0f0f0f",
  "orientation": "portrait-primary",
  "icons": [],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text":  "text",
      "url":   "url",
      "files": [
        { "name": "file", "accept": ["image/*", "application/pdf", "text/*"] }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "Capture note",
      "url":  "/?mode=capture",
      "description": "Quickly capture a new note"
    }
  ],
  "categories": ["productivity", "utilities"]
}
